# Root GitIgnore for Stream.Tv Monorepo

# Dependencies
node_modules/

# Next.js Build files
client/.next/
client/out/
client/build/
client/.next-env.d.ts
client/tsconfig.tsbuildinfo

# Node Server build files
server/dist/

# Uploaded media assets
server/uploads/*
!server/uploads/.gitkeep

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
server/.env
client/.env.local

# OS files
.DS_Store
Thumbs.db
